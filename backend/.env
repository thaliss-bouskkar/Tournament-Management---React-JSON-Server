# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/tournamentDB?retryWrites=true&w=majority

# Express port (Vercel يختاره تلقائياً، يمكن تخليه 5000 للـ local)
PORT=5000

# Frontend URL بعد deploy
FRONTEND_URL=https://your-vercel-app-url.vercel.app

# Email configuration (Gmail مثال)
EMAIL_SERVICE=gmail
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# Node environment
NODE_ENV=production